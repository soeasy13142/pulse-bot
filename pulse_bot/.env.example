TELEGRAM_BOT_TOKEN=your-token-from-botfather
VAULT_REPO_DIR=/opt/pulse-bot/vault
GIT_REMOTE=origin
GIT_BRANCH=master
LOG_LEVEL=INFO
PULSE_BOT_CONFIG=/etc/pulse-bot/config.yaml
DEAD_LETTER_PATH=/opt/pulse-bot/dead_letter.jsonl

# Graceful shutdown timeout (seconds)
SHUTDOWN_TIMEOUT=30

# Logging format: 'json' or 'text'
LOG_FORMAT=json

# DLQ alert threshold (number of failures before alert)
DLQ_ALERT_THRESHOLD=5

# DLQ alert cooldown (seconds between alerts)
DLQ_ALERT_COOLDOWN=3600
